{
  "spec": {
    "title": "Digital Credentials",
    "url": "https://www.w3.org/TR/digital-credentials/"
  },
  "algorithms": [
    {
      "name": "credential request coordinator/prepare credential requests",
      "href": "https://www.w3.org/TR/digital-credentials/#dfn-prepare-credential-requests",
      "html": "To <dfn data-dfn-for=\"credential request coordinator\" id=\"dfn-prepare-credential-requests\" tabindex=\"0\" aria-haspopup=\"dialog\" data-dfn-type=\"dfn\">prepare credential\n      requests</dfn> given a <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#concept-document\" id=\"ref-for-index-term-document-1\">Document</a> <var data-type=\"Document\">document</var>, a <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#idl-sequence\" id=\"ref-for-index-term-sequence-1\">sequence</a>\n      of <a data-link-type=\"idl\" data-lt=\"DigitalCredentialGetRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialgetrequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialgetrequest-1\"><code>DigitalCredentialGetRequest</code></a> values or a <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#idl-sequence\" id=\"ref-for-index-term-sequence-2\">sequence</a> of\n      <a data-link-type=\"idl\" data-lt=\"DigitalCredentialCreateRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialcreaterequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialcreaterequest-1\"><code>DigitalCredentialCreateRequest</code></a> values <var>requests</var>, a <a data-link-type=\"interface\" data-lt=\"Promise\" href=\"https://webidl.spec.whatwg.org/#idl-promise\" id=\"ref-for-index-term-promise-interface-2\"><code>Promise</code></a>\n      <var data-type=\"Promise\">promise</var>, and an optional <a data-link-type=\"interface\" data-lt=\"AbortSignal\" href=\"https://dom.spec.whatwg.org/#abortsignal\" id=\"ref-for-index-term-abortsignal-interface-2\"><code>AbortSignal</code></a> <var data-type=\"AbortSignal\">signal</var>:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "Let <var>global</var> be <var data-type=\"Document\">document</var>'s <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#concept-relevant-global\" id=\"ref-for-index-term-relevant-global-object-1\">relevant global object</a>."
        },
        {
          "html": "If the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-8\">credential request coordinator</a> is not in the \"<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-idle\" class=\"internalDFN\" id=\"ref-for-dfn-idle-3\">idle</a>\" <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-interaction-states\" class=\"internalDFN\" id=\"ref-for-dfn-interaction-states-3\">interaction state</a>:",
          "rationale": "queue",
          "steps": [
            {
              "html": "<a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#queue-a-global-task\" id=\"ref-for-index-term-queue-a-global-task-1\">Queue a global task</a> on the <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#dom-manipulation-task-source\" id=\"ref-for-index-term-dom-manipulation-task-source-1\">DOM manipulation task source</a>\n          given <var>global</var> to <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#reject\" id=\"ref-for-index-term-rejects-3\">reject</a> <var data-type=\"Promise\">promise</var> with a \"<a data-link-type=\"exception\" href=\"https://webidl.spec.whatwg.org/#notallowederror\" id=\"ref-for-index-term-notallowederror-exception-1\"><code>NotAllowedError</code></a>\"\n          <a data-link-type=\"interface\" data-lt=\"DOMException\" href=\"https://webidl.spec.whatwg.org/#idl-DOMException\" id=\"ref-for-index-term-domexception-interface-1\"><code>DOMException</code></a>."
            },
            {
              "html": "Return."
            }
          ]
        },
        {
          "html": "<a href=\"https://infra.spec.whatwg.org/#assert\">Assert</a>: the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-9\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-2\">active promise</a> is <code>null</code>."
        },
        {
          "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-10\">credential request coordinator</a> <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-interaction-states\" class=\"internalDFN\" id=\"ref-for-dfn-interaction-states-4\">interaction state</a> to \"<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-requesting\" class=\"internalDFN\" id=\"ref-for-dfn-requesting-1\">requesting</a>\"."
        },
        {
          "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-11\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-3\">active promise</a> to <var data-type=\"Promise\">promise</var>."
        },
        {
          "html": "If <var data-type=\"AbortSignal\">signal</var> was passed:",
          "rationale": "assert",
          "steps": [
            {
              "html": "<a href=\"https://infra.spec.whatwg.org/#assert\">Assert</a>: <var data-type=\"AbortSignal\">signal</var> is not <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-aborted\" id=\"ref-for-index-term-aborted-for-abortsignal-1\">aborted</a>."
            },
            {
              "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-12\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-signal\" class=\"internalDFN\" id=\"ref-for-dfn-abort-signal-1\">abort signal</a> to <var data-type=\"AbortSignal\">signal</var>."
            },
            {
              "html": "Let <var>abortAlgorithm</var> be the following algorithm:",
              "rationale": "if",
              "steps": [
                {
                  "html": "If the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-13\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-4\">active promise</a> is not <var data-type=\"Promise\">promise</var>, return."
                },
                {
                  "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-the-credential-request\" class=\"internalDFN\" id=\"ref-for-dfn-abort-the-credential-request-1\">Abort the credential request</a> given <var data-type=\"AbortSignal\">signal</var>'s <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-abort-reason\" id=\"ref-for-index-term-abort-reason-for-abortsignal-1\">abort reason</a>."
                }
              ]
            },
            {
              "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-14\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-algorithm\" class=\"internalDFN\" id=\"ref-for-dfn-abort-algorithm-1\">abort algorithm</a> to <var>abortAlgorithm</var>."
            },
            {
              "html": "<a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-add\" id=\"ref-for-index-term-add-for-abortsignal-1\">Add</a> <var>abortAlgorithm</var> to <var data-type=\"AbortSignal\">signal</var>."
            }
          ]
        },
        {
          "html": "Let <var>validatedRequests</var> be the result of <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-validate-credential-requests\" class=\"internalDFN\" id=\"ref-for-dfn-validate-credential-requests-1\">validate credential requests</a> given <var>requests</var>. If that\n      <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-throw\" id=\"ref-for-index-term-throws-for-exception-1\">throws</a> an <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-exception\" id=\"ref-for-index-term-exception-1\">exception</a> <var>error</var>:",
          "rationale": "reject",
          "steps": [
            {
              "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-reject-the-credential-request-with\" class=\"internalDFN\" id=\"ref-for-dfn-reject-the-credential-request-with-1\">Reject the credential request with</a> <var>error</var> and <var data-type=\"Promise\">promise</var>."
            },
            {
              "html": "Return."
            }
          ]
        },
        {
          "html": "If <var>validatedRequests</var> <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list-is-empty\" id=\"ref-for-index-term-is-empty-for-list-1\">is empty</a>:",
          "rationale": "reject",
          "steps": [
            {
              "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-reject-the-credential-request-with\" class=\"internalDFN\" id=\"ref-for-dfn-reject-the-credential-request-with-2\">Reject the credential request with</a> a newly created <a data-link-type=\"exception\" data-lt=\"TypeError\" href=\"https://webidl.spec.whatwg.org/#exceptiondef-typeerror\" id=\"ref-for-index-term-typeerror-exception-1\"><code>TypeError</code></a> and <var data-type=\"Promise\">promise</var>."
            },
            {
              "html": "Return."
            }
          ]
        },
        {
          "html": "If <var data-type=\"AbortSignal\">signal</var> was passed and <var data-type=\"AbortSignal\">signal</var> is <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-aborted\" id=\"ref-for-index-term-aborted-for-abortsignal-3\">aborted</a>:",
          "rationale": "let",
          "steps": [
            {
              "html": "Let <var>error</var> be <var data-type=\"AbortSignal\">signal</var>'s <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-abort-reason\" id=\"ref-for-index-term-abort-reason-for-abortsignal-2\">abort reason</a>."
            },
            {
              "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-reject-the-credential-request-with\" class=\"internalDFN\" id=\"ref-for-dfn-reject-the-credential-request-with-3\">Reject the credential request with</a> <var>error</var> and <var data-type=\"Promise\">promise</var>."
            },
            {
              "html": "Return."
            }
          ]
        },
        {
          "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-present-the-credential-request\" class=\"internalDFN\" id=\"ref-for-dfn-present-the-credential-request-1\">Present the credential request</a>\n      with <var data-type=\"Document\">document</var>, <var>validatedRequests</var>, and <var data-type=\"AbortSignal\">signal</var>."
        },
        {
          "html": "If <var data-type=\"Document\">document</var> stops being <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/document-sequences.html#fully-active\" id=\"ref-for-index-term-fully-active-for-document-1\">fully active</a>, <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-the-credential-request\" class=\"internalDFN\" id=\"ref-for-dfn-abort-the-credential-request-2\">abort the credential request</a> with an\n      \"<a data-link-type=\"exception\" href=\"https://webidl.spec.whatwg.org/#aborterror\" id=\"ref-for-index-term-aborterror-exception-1\"><code>AbortError</code></a>\" <a data-link-type=\"interface\" data-lt=\"DOMException\" href=\"https://webidl.spec.whatwg.org/#idl-DOMException\" id=\"ref-for-index-term-domexception-interface-2\"><code>DOMException</code></a>."
        }
      ]
    },
    {
      "name": "credential request coordinator/validate credential requests",
      "href": "https://www.w3.org/TR/digital-credentials/#dfn-validate-credential-requests",
      "html": "To <dfn data-dfn-for=\"credential request coordinator\" id=\"dfn-validate-credential-requests\" tabindex=\"0\" aria-haspopup=\"dialog\" data-dfn-type=\"dfn\">validate credential\n      requests</dfn> given a sequence of <a data-link-type=\"idl\" data-lt=\"DigitalCredentialGetRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialgetrequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialgetrequest-2\"><code>DigitalCredentialGetRequest</code></a> or\n      <a data-link-type=\"idl\" data-lt=\"DigitalCredentialCreateRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialcreaterequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialcreaterequest-2\"><code>DigitalCredentialCreateRequest</code></a> objects <var>requests</var>:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "Let <var>validatedRequests</var> be a new empty <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list\" id=\"ref-for-index-term-list-1\">list</a>."
        },
        {
          "html": "<a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list-iterate\" id=\"ref-for-index-term-for-each-for-list-1\">For each</a> <var>request</var> of <var>requests</var>:",
          "rationale": "let",
          "steps": [
            {
              "html": "Let <var>protocol</var> be <var>request</var>'s\n          <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialgetrequest-protocol\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialgetrequest-protocol-1\"><code>protocol</code></a>, if <var>request</var> is a\n          <a data-link-type=\"idl\" data-lt=\"DigitalCredentialGetRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialgetrequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialgetrequest-3\"><code>DigitalCredentialGetRequest</code></a>, or <var>request</var>'s\n          <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialcreaterequest-protocol\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialcreaterequest-protocol-1\"><code>protocol</code></a>, if <var>request</var> is a\n          <a data-link-type=\"idl\" data-lt=\"DigitalCredentialCreateRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialcreaterequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialcreaterequest-3\"><code>DigitalCredentialCreateRequest</code></a>."
            },
            {
              "html": "If <var>request</var> is a <a data-link-type=\"idl\" data-lt=\"DigitalCredentialGetRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialgetrequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialgetrequest-4\"><code>DigitalCredentialGetRequest</code></a> and <var>protocol</var>\n          does not equal any <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-enumeration-value\" id=\"ref-for-index-term-enumeration-value-1\">enumeration value</a> in\n          <a data-link-type=\"idl\" data-lt=\"DigitalCredentialPresentationProtocol\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialpresentationprotocol\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialpresentationprotocol-1\"><code>DigitalCredentialPresentationProtocol</code></a>, <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#iteration-continue\" id=\"ref-for-index-term-continue-for-iteration-1\">continue</a>."
            },
            {
              "html": "If <var>request</var> is a <a data-link-type=\"idl\" data-lt=\"DigitalCredentialCreateRequest\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialcreaterequest\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialcreaterequest-4\"><code>DigitalCredentialCreateRequest</code></a> and\n          <var>protocol</var> does not equal any <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-enumeration-value\" id=\"ref-for-index-term-enumeration-value-2\">enumeration value</a> in\n          <a data-link-type=\"idl\" data-lt=\"DigitalCredentialIssuanceProtocol\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialissuanceprotocol\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialissuanceprotocol-1\"><code>DigitalCredentialIssuanceProtocol</code></a>, <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#iteration-continue\" id=\"ref-for-index-term-continue-for-iteration-2\">continue</a>."
            },
            {
              "html": "If the <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#user-agent\" id=\"ref-for-index-term-user-agents-0-6\">user agent</a> does not allow <var>protocol</var>,\n          <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#iteration-continue\" id=\"ref-for-index-term-continue-for-iteration-3\">continue</a>."
            },
            {
              "html": "Validate <var>request</var>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-request-data\" class=\"internalDFN\" id=\"ref-for-dfn-request-data-3\">request data</a>\n          according to <var>request</var>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-presentation-protocol\" class=\"internalDFN\" id=\"ref-for-dfn-presentation-protocol-9\">presentation protocol</a>\n          or <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-issuance-protocol\" class=\"internalDFN\" id=\"ref-for-dfn-issuance-protocol-8\">issuance protocol</a> or other criteria.\n          Validation requirements are protocol-specific and are outside the\n          scope of this specification:",
              "rationale": "if",
              "steps": [
                {
                  "html": "If validation fails, <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-throw\" id=\"ref-for-index-term-throws-for-exception-2\">throw</a> an appropriate\n              <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-exception\" id=\"ref-for-index-term-exception-2\">exception</a>."
                },
                {
                  "html": "Otherwise, <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list-append\" id=\"ref-for-index-term-append-for-list-1\">append</a> <var>request</var> to <var>validatedRequests</var>."
                }
              ]
            }
          ]
        },
        {
          "html": "Return <var>validatedRequests</var>."
        }
      ]
    },
    {
      "name": "credential request coordinator/abort the credential request",
      "href": "https://www.w3.org/TR/digital-credentials/#dfn-abort-the-credential-request",
      "html": "To <dfn data-dfn-for=\"credential request coordinator\" id=\"dfn-abort-the-credential-request\" tabindex=\"0\" aria-haspopup=\"dialog\" data-dfn-type=\"dfn\">abort the\n      credential request</dfn> given a JavaScript value or <a data-link-type=\"interface\" data-lt=\"DOMException\" href=\"https://webidl.spec.whatwg.org/#idl-DOMException\" id=\"ref-for-index-term-domexception-interface-3\"><code>DOMException</code></a>\n      <var>error</var>:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "If the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-15\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-5\">active promise</a> is <code>null</code>, return."
        },
        {
          "html": "Let <var>activePromise</var> be the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-16\">credential request coordinator</a>'s\n      <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-6\">active promise</a>."
        },
        {
          "html": "If the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-17\">credential request coordinator</a> is in the \"<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-requesting\" class=\"internalDFN\" id=\"ref-for-dfn-requesting-2\">requesting</a>\" <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-interaction-states\" class=\"internalDFN\" id=\"ref-for-dfn-interaction-states-5\">interaction state</a>:",
          "rationale": "set",
          "steps": [
            {
              "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-18\">credential request coordinator</a> <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-interaction-states\" class=\"internalDFN\" id=\"ref-for-dfn-interaction-states-6\">interaction state</a> to \"<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-aborting\" class=\"internalDFN\" id=\"ref-for-dfn-aborting-1\">aborting</a>\"."
            },
            {
              "html": "Dismiss the <a data-link-type=\"dfn\" href=\"https://www.w3.org/TR/credential-management-1/#credential-chooser\" id=\"ref-for-index-term-credential-chooser-2\">credential chooser</a>."
            }
          ]
        },
        {
          "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-reject-the-credential-request-with\" class=\"internalDFN\" id=\"ref-for-dfn-reject-the-credential-request-with-4\">Reject the credential request with</a>\n      <var>error</var> and <var>activePromise</var>."
        }
      ]
    },
    {
      "name": "credential request coordinator/reject the credential request with",
      "href": "https://www.w3.org/TR/digital-credentials/#dfn-reject-the-credential-request-with",
      "html": "To <dfn data-dfn-for=\"credential request coordinator\" id=\"dfn-reject-the-credential-request-with\" tabindex=\"0\" aria-haspopup=\"dialog\" data-dfn-type=\"dfn\">reject the\n      credential request with</dfn> a (JavaScript Value) <var>error</var> and a\n      <a data-link-type=\"interface\" data-lt=\"Promise\" href=\"https://webidl.spec.whatwg.org/#idl-promise\" id=\"ref-for-index-term-promise-interface-3\"><code>Promise</code></a> <var data-type=\"Promise\">promise</var>:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "<a href=\"https://infra.spec.whatwg.org/#assert\">Assert</a>: the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-20\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-7\">active promise</a> is <var data-type=\"Promise\">promise</var>."
        },
        {
          "html": "<a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#queue-a-global-task\" id=\"ref-for-index-term-queue-a-global-task-2\">Queue a global task</a> on the <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#dom-manipulation-task-source\" id=\"ref-for-index-term-dom-manipulation-task-source-2\">DOM manipulation task source</a> given\n      <var data-type=\"Promise\">promise</var>'s <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#concept-relevant-global\" id=\"ref-for-index-term-relevant-global-object-2\">relevant global object</a> to perform the following steps:",
          "rationale": "if",
          "steps": [
            {
              "html": "If the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-21\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-8\">active promise</a> is not <var data-type=\"Promise\">promise</var>, then return."
            },
            {
              "html": "Let <var>signal</var> be the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-22\">credential request coordinator</a>'s\n          <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-signal\" class=\"internalDFN\" id=\"ref-for-dfn-abort-signal-2\">abort signal</a>."
            },
            {
              "html": "Let <var>abortAlgorithm</var> be the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-23\">credential request coordinator</a>'s\n          <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-algorithm\" class=\"internalDFN\" id=\"ref-for-dfn-abort-algorithm-2\">abort algorithm</a>."
            },
            {
              "html": "If <var>signal</var> is not <code>null</code> and <var>abortAlgorithm</var> is not <code>null</code>:",
              "rationale": "remove",
              "steps": [
                {
                  "html": "<a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-remove\" id=\"ref-for-index-term-remove-for-abortsignal-1\">Remove</a> <var>abortAlgorithm</var> from <var>signal</var>."
                }
              ]
            },
            {
              "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-24\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-signal\" class=\"internalDFN\" id=\"ref-for-dfn-abort-signal-3\">abort signal</a> to <code>null</code>."
            },
            {
              "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-25\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-abort-algorithm\" class=\"internalDFN\" id=\"ref-for-dfn-abort-algorithm-3\">abort algorithm</a> to <code>null</code>."
            },
            {
              "html": "<a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#reject\" id=\"ref-for-index-term-rejects-4\">Reject</a> <var data-type=\"Promise\">promise</var> with <var>error</var>."
            },
            {
              "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-26\">credential request coordinator</a>'s <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-active-promise\" class=\"internalDFN\" id=\"ref-for-dfn-active-promise-9\">active promise</a> to <code>null</code>."
            },
            {
              "html": "Set the <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-credential-request-coordinator\" class=\"internalDFN\" id=\"ref-for-dfn-credential-request-coordinator-27\">credential request coordinator</a> <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-interaction-states\" class=\"internalDFN\" id=\"ref-for-dfn-interaction-states-7\">interaction state</a> to \"<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-idle\" class=\"internalDFN\" id=\"ref-for-dfn-idle-4\">idle</a>\"."
            }
          ]
        }
      ]
    },
    {
      "html": "When this method is invoked, the user agent <em class=\"rfc2119\">MUST</em> execute the following\n      algorithm:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "If <var>protocol</var> is not an <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-enumeration-value\" id=\"ref-for-index-term-enumeration-value-3\">enumeration value</a> of\n      <a data-link-type=\"idl\" data-lt=\"DigitalCredentialProtocol\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialprotocol\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialprotocol-2\"><code>DigitalCredentialProtocol</code></a>, return <code>false</code>."
        },
        {
          "html": "Return <code>true</code> if the user agent allows <var>protocol</var>, otherwise return\n      <code>false</code>."
        }
      ]
    },
    {
      "name": "DigitalCredential/[[DiscoverFromExternalSource]](origin, options, sameOriginWithAncestors)",
      "href": "https://www.w3.org/TR/digital-credentials/#dfn-discoverfromexternalsource-origin-options-sameoriginwithancestors",
      "html": "When invoked, the <dfn class=\"export\" data-dfn-for=\"DigitalCredential\" data-idl=\"\" data-dfn-type=\"method\" data-export=\"\" id=\"dfn-discoverfromexternalsource-origin-options-sameoriginwithancestors\" tabindex=\"0\" aria-haspopup=\"dialog\">[[DiscoverFromExternalSource]](origin, options,\n      sameOriginWithAncestors)</dfn> internal method, if the user agent doesn't\n      support <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-presentation-request\" class=\"internalDFN\" id=\"ref-for-dfn-presentation-request-17\">presentation requests</a> (e.g., the platform\n      cannot provide a <a data-link-type=\"dfn\" href=\"https://www.w3.org/TR/credential-management-1/#credential-chooser\" id=\"ref-for-index-term-credential-chooser-5\">credential chooser</a>), call the default implementation\n      of <a data-link-type=\"interface\" data-lt=\"Credential\" href=\"https://www.w3.org/TR/credential-management-1/#credential\" id=\"ref-for-index-term-credential-interface-2\"><code>Credential</code></a>'s <a data-link-type=\"method\" data-lt=\"[[DiscoverFromExternalSource]](origin, options, sameOriginWithAncestors)\" href=\"https://www.w3.org/TR/credential-management-1/#dom-credential-discoverfromexternalsource-slot\" id=\"ref-for-index-term-discoverfromexternalsource-origin-options-sameoriginwithancestors-for-credential-1\"><code>[[DiscoverFromExternalSource]](<var>origin</var>, <var>options</var>, <var>sameOriginWithAncestors</var>)</code></a> internal method with the same\n      arguments. Otherwise:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "Let <var>signal</var> be <var>options</var>'s <a data-link-type=\"dict-member\" href=\"https://www.w3.org/TR/credential-management-1/#dom-credentialrequestoptions-signal\" id=\"ref-for-index-term-signal-for-credentialrequestoptions-1\"><code>signal</code></a>, if\n      present."
        },
        {
          "html": "If <var>signal</var> is <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-aborted\" id=\"ref-for-index-term-aborted-for-abortsignal-4\">aborted</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-1\">a promise rejected with</a> <var>signal</var>'s <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-abort-reason\" id=\"ref-for-index-term-abort-reason-for-abortsignal-3\">abort reason</a>."
        },
        {
          "html": "Let <var>global</var> be <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#this\" id=\"ref-for-index-term-this-1\">this</a>'s <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#concept-relevant-global\" id=\"ref-for-index-term-relevant-global-object-3\">relevant global object</a>."
        },
        {
          "html": "Let <var>document</var> be <var>global</var>'s <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/nav-history-apis.html#concept-document-window\" id=\"ref-for-index-term-associated-document-1\">associated <code>Document</code></a>."
        },
        {
          "html": "If <var>document</var> is not a <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/interaction.html#fully-active-descendant-of-a-top-level-traversable-with-user-attention\" id=\"ref-for-index-term-fully-active-descendant-of-a-top-level-traversable-with-user-attention-for-document-1\">fully active descendant of a top-level traversable with user attention</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-2\">a promise rejected with</a> a \"<a data-link-type=\"exception\" href=\"https://webidl.spec.whatwg.org/#notallowederror\" id=\"ref-for-index-term-notallowederror-exception-2\"><code>NotAllowedError</code></a>\" <a data-link-type=\"interface\" data-lt=\"DOMException\" href=\"https://webidl.spec.whatwg.org/#idl-DOMException\" id=\"ref-for-index-term-domexception-interface-4\"><code>DOMException</code></a>."
        },
        {
          "html": "Let <var>requests</var> be <var>options</var>'s <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-credentialrequestoptions-digital\" class=\"internalDFN\" id=\"ref-for-dom-credentialrequestoptions-digital-2\"><code>digital</code></a>'s\n      <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialrequestoptions-requests\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialrequestoptions-requests-2\"><code>requests</code></a> member."
        },
        {
          "html": "If <var>requests</var> <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list-is-empty\" id=\"ref-for-index-term-is-empty-for-list-2\">is empty</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-3\">a promise rejected with</a> a\n      <a data-link-type=\"exception\" data-lt=\"TypeError\" href=\"https://webidl.spec.whatwg.org/#exceptiondef-typeerror\" id=\"ref-for-index-term-typeerror-exception-2\"><code>TypeError</code></a>."
        },
        {
          "html": "<a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list-iterate\" id=\"ref-for-index-term-for-each-for-list-2\">For each</a> <var>request</var> of <var>requests</var>:",
          "rationale": "serialize",
          "steps": [
            {
              "html": "<a data-link-type=\"dfn\" data-lt=\"serialize a JavaScript value to a JSON string\" href=\"https://infra.spec.whatwg.org/#serialize-a-javascript-value-to-a-json-string\" id=\"ref-for-index-term-serialize-a-javascript-value-to-a-json-string-1\">Serialize</a>\n          <var>request</var>'s <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialgetrequest-data\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialgetrequest-data-2\"><code>data</code></a> to a JSON string."
            },
            {
              "html": "If serialization results in an <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-exception\" id=\"ref-for-index-term-exception-3\">exception</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-4\">a promise rejected with</a> that <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-exception\" id=\"ref-for-index-term-exception-4\">exception</a>."
            }
          ]
        },
        {
          "html": "If <var>global</var> does not have <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/interaction.html#transient-activation\" id=\"ref-for-index-term-transient-activation-2\">transient activation</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-5\">a promise rejected with</a> a \"<a data-link-type=\"exception\" href=\"https://webidl.spec.whatwg.org/#notallowederror\" id=\"ref-for-index-term-notallowederror-exception-3\"><code>NotAllowedError</code></a>\" <a data-link-type=\"interface\" data-lt=\"DOMException\" href=\"https://webidl.spec.whatwg.org/#idl-DOMException\" id=\"ref-for-index-term-domexception-interface-5\"><code>DOMException</code></a>."
        },
        {
          "html": "<a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/interaction.html#consume-user-activation\" id=\"ref-for-index-term-consume-user-activation-1\">Consume user activation</a> of <var>global</var>."
        },
        {
          "html": "Let <var>promise</var> be <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-new-promise\" id=\"ref-for-index-term-a-new-promise-1\">a new promise</a> in <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#this\" id=\"ref-for-index-term-this-2\">this</a>'s <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#concept-relevant-realm\" id=\"ref-for-index-term-relevant-realm-1\">relevant realm</a>."
        },
        {
          "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-prepare-credential-requests\" class=\"internalDFN\" id=\"ref-for-dfn-prepare-credential-requests-1\">Prepare credential requests</a> with\n      <var>document</var>, <var>requests</var>, <var>promise</var>, and <var>signal</var>."
        },
        {
          "html": "Return <var>promise</var>."
        }
      ]
    },
    {
      "name": "DigitalCredential/[[Create]](origin, options, sameOriginWithAncestors)",
      "href": "https://www.w3.org/TR/digital-credentials/#dfn-create-origin-options-sameoriginwithancestors",
      "html": "When invoked, the <dfn class=\"export\" data-dfn-for=\"DigitalCredential\" data-idl=\"\" data-dfn-type=\"method\" data-export=\"\" id=\"dfn-create-origin-options-sameoriginwithancestors\" tabindex=\"0\" aria-haspopup=\"dialog\">[[Create]](origin, options,\n      sameOriginWithAncestors)</dfn> internal method, if the user agent doesn't\n      support <a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-issuance-request\" class=\"internalDFN\" id=\"ref-for-dfn-issuance-request-16\">issuance requests</a>, call the default\n      implementation of <a data-link-type=\"interface\" data-lt=\"Credential\" href=\"https://www.w3.org/TR/credential-management-1/#credential\" id=\"ref-for-index-term-credential-interface-4\"><code>Credential</code></a>'s <a data-link-type=\"method\" data-lt=\"[[Create]](origin, options, sameOriginWithAncestors)\" href=\"https://www.w3.org/TR/credential-management-1/#dom-credential-create-slot\" id=\"ref-for-index-term-create-origin-options-sameoriginwithancestors-for-credential-2\"><code>[[Create]](<var>origin</var>, <var>options</var>, <var>sameOriginWithAncestors</var>)</code></a> internal method with the same\n      arguments. Otherwise:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "Let <var>signal</var> be <var>options</var>'s <a data-link-type=\"dict-member\" href=\"https://www.w3.org/TR/credential-management-1/#dom-credentialcreationoptions-signal\" id=\"ref-for-index-term-signal-for-credentialcreationoptions-1\"><code>signal</code></a>, if\n      present."
        },
        {
          "html": "If <var>signal</var> is <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-aborted\" id=\"ref-for-index-term-aborted-for-abortsignal-5\">aborted</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-6\">a promise rejected with</a> <var>signal</var>'s <a data-link-type=\"dfn\" href=\"https://dom.spec.whatwg.org/#abortsignal-abort-reason\" id=\"ref-for-index-term-abort-reason-for-abortsignal-4\">abort reason</a>."
        },
        {
          "html": "Let <var>global</var> be <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#this\" id=\"ref-for-index-term-this-3\">this</a>'s <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/webappapis.html#concept-relevant-global\" id=\"ref-for-index-term-relevant-global-object-4\">relevant global object</a>."
        },
        {
          "html": "Let <var>document</var> be <var>global</var>'s <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/nav-history-apis.html#concept-document-window\" id=\"ref-for-index-term-associated-document-2\">associated <code>Document</code></a>."
        },
        {
          "html": "If <var>document</var> is not a <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/interaction.html#fully-active-descendant-of-a-top-level-traversable-with-user-attention\" id=\"ref-for-index-term-fully-active-descendant-of-a-top-level-traversable-with-user-attention-for-document-2\">fully active descendant of a top-level traversable with user attention</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-7\">a promise rejected with</a> a \"<a data-link-type=\"exception\" href=\"https://webidl.spec.whatwg.org/#notallowederror\" id=\"ref-for-index-term-notallowederror-exception-4\"><code>NotAllowedError</code></a>\" <a data-link-type=\"interface\" data-lt=\"DOMException\" href=\"https://webidl.spec.whatwg.org/#idl-DOMException\" id=\"ref-for-index-term-domexception-interface-6\"><code>DOMException</code></a>."
        },
        {
          "html": "Let <var>requests</var> be <var>options</var>'s <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-credentialcreationoptions-digital\" class=\"internalDFN\" id=\"ref-for-dom-credentialcreationoptions-digital-2\"><code>digital</code></a>'s\n      <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialcreationoptions-requests\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialcreationoptions-requests-2\"><code>requests</code></a> member."
        },
        {
          "html": "If <var>requests</var> is <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list-is-empty\" id=\"ref-for-index-term-is-empty-for-list-3\">is empty</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-8\">a promise rejected with</a> a <a data-link-type=\"exception\" data-lt=\"TypeError\" href=\"https://webidl.spec.whatwg.org/#exceptiondef-typeerror\" id=\"ref-for-index-term-typeerror-exception-3\"><code>TypeError</code></a>."
        },
        {
          "html": "<a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#list-iterate\" id=\"ref-for-index-term-for-each-for-list-3\">For each</a> <var>request</var> of <var>requests</var>:",
          "rationale": "serialize",
          "steps": [
            {
              "html": "<a data-link-type=\"dfn\" data-lt=\"serialize a JavaScript value to a JSON string\" href=\"https://infra.spec.whatwg.org/#serialize-a-javascript-value-to-a-json-string\" id=\"ref-for-index-term-serialize-a-javascript-value-to-a-json-string-2\">Serialize</a>\n          <var>request</var>'s <a data-link-type=\"idl\" href=\"https://www.w3.org/TR/digital-credentials/#dom-digitalcredentialgetrequest-data\" class=\"internalDFN\" id=\"ref-for-dom-digitalcredentialgetrequest-data-3\"><code>data</code></a> to a JSON string."
            },
            {
              "html": "If serialization results in an <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-exception\" id=\"ref-for-index-term-exception-5\">exception</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-9\">a promise rejected with</a> that <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#dfn-exception\" id=\"ref-for-index-term-exception-6\">exception</a>."
            }
          ]
        },
        {
          "html": "If <var>global</var> does not have <a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/interaction.html#transient-activation\" id=\"ref-for-index-term-transient-activation-3\">transient activation</a>, return <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-promise-rejected-with\" id=\"ref-for-index-term-a-promise-rejected-with-10\">a promise rejected with</a> a \"<a data-link-type=\"exception\" href=\"https://webidl.spec.whatwg.org/#notallowederror\" id=\"ref-for-index-term-notallowederror-exception-5\"><code>NotAllowedError</code></a>\" <a data-link-type=\"interface\" data-lt=\"DOMException\" href=\"https://webidl.spec.whatwg.org/#idl-DOMException\" id=\"ref-for-index-term-domexception-interface-7\"><code>DOMException</code></a>."
        },
        {
          "html": "<a data-link-type=\"dfn\" href=\"https://html.spec.whatwg.org/multipage/interaction.html#consume-user-activation\" id=\"ref-for-index-term-consume-user-activation-2\">Consume user activation</a> of <var>global</var>."
        },
        {
          "html": "Let <var>promise</var> be <a data-link-type=\"dfn\" href=\"https://webidl.spec.whatwg.org/#a-new-promise\" id=\"ref-for-index-term-a-new-promise-2\">a new promise</a>."
        },
        {
          "html": "<a data-link-type=\"dfn|abstract-op\" href=\"https://www.w3.org/TR/digital-credentials/#dfn-prepare-credential-requests\" class=\"internalDFN\" id=\"ref-for-dfn-prepare-credential-requests-2\">Prepare credential requests</a> with\n      <var>document</var>, <var>requests</var>, <var>promise</var>, and <var>signal</var>."
        },
        {
          "html": "Return <var>promise</var>."
        }
      ]
    }
  ]
}