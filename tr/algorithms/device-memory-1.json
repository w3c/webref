{
  "spec": {
    "title": "Device Memory API",
    "url": "https://www.w3.org/TR/device-memory-1/"
  },
  "algorithms": [
    {
      "name": "deviceMemory",
      "href": "https://www.w3.org/TR/device-memory-1/#devicememory",
      "html": "The <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#user-agent\" id=\"ref-for-user-agent\">user agent</a>’s <dfn class=\"dfn-paneled has-dfn-panel\" data-dfn-type=\"dfn\" data-noexport=\"\" id=\"devicememory\" role=\"button\" aria-expanded=\"false\" tabindex=\"0\">deviceMemory</dfn> is calculated by these steps:",
      "rationale": ".algorithm",
      "steps": [
        {
          "html": "<p>Let <var>physicalDeviceMemory</var> be the amount of physical memory in bytes.</p>"
        },
        {
          "html": "<p>Let <var>minimumLowerBound</var> be an <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#implementation-defined\" id=\"ref-for-implementation-defined\">implementation-defined</a> minimum bound.</p>"
        },
        {
          "html": "<p>Let <var>maximumUpperBound</var> be an <a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#implementation-defined\" id=\"ref-for-implementation-defined①\">implementation-defined</a> maximum bound.</p>"
        },
        {
          "html": "<p>Let <var>deviceMemory</var> be <var>physicalDeviceMemory</var> / 1024.0.</p>"
        },
        {
          "html": "<p>Let <var>power</var> be 0.</p>"
        },
        {
          "html": "<a data-link-type=\"dfn\" href=\"https://infra.spec.whatwg.org/#iteration-while\" id=\"ref-for-iteration-while\">While</a> <var>deviceMemory</var> is greater than 1:",
          "rationale": "increment",
          "steps": [
            {
              "html": "<p>Bitwise shift <var>deviceMemory</var> right 1 place.</p>"
            },
            {
              "html": "<p>Increment <var>power</var> by 1.</p>"
            }
          ]
        },
        {
          "html": "<p>Let <var>lowerBound</var> be 2 to the power of <var>power</var>.</p>"
        },
        {
          "html": "<p>Let <var>upperBound</var> be 2 to the power of |power + 1|.</p>"
        },
        {
          "html": "<p>If <var>physicalDeviceMemory</var> − <var>lowerBound</var> ≤ <var>upperBound</var> − <var>physicalDeviceMemory</var>, then <var>deviceMemory</var>’s value is <var>lowerBound</var>.</p>"
        },
        {
          "html": "<p>Otherwise <var>deviceMemory</var>’s value is <var>upperBound</var>.</p>"
        },
        {
          "html": "<p>If <var>deviceMemory</var> &lt; <var>minimumLowerBound</var>, then <var>deviceMemory</var> is <var>minimumLowerBound</var>.</p>"
        },
        {
          "html": "<p>If <var>deviceMemory</var> &gt; <var>maximumUpperBound</var>, then <var>deviceMemory</var> is <var>maximumUpperBound</var>.</p>"
        },
        {
          "html": "<p>Return <var>deviceMemory</var>.</p>"
        }
      ]
    }
  ]
}