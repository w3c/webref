// Source: CSS Animations Module Level 1 (https://www.w3.org/TR/css-animations-1/)
dictionary AnimationEventInit : EventInit {
  CSSOMString animationName = "";
  double elapsedTime = 0.0;
  CSSOMString pseudoElement = "";
};

// Source: CSS Animations Module Level 2 (https://www.w3.org/TR/css-animations-2/)
partial dictionary AnimationEventInit {
  CSSAnimation? animation = null;
};