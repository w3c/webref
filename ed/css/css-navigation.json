{
  "spec": {
    "title": "CSS Route Matching",
    "url": "https://drafts.csswg.org/css-navigation-1/"
  },
  "properties": [],
  "atrules": [
    {
      "name": "@route",
      "prose": "The @route rule is an at-rule that associates a name with a URL pattern. This name can be referenced in @navigation rules and in :active-navigation() pseudo-classes.",
      "href": "https://drafts.csswg.org/css-navigation-1/#at-ruledef-route",
      "descriptors": []
    },
    {
      "name": "@navigation",
      "prose": "The @navigation rule is a conditional group rule whose condition tests characteristics of the current URL or of the state of navigation between two URLs. These queries are called navigation queries.",
      "href": "https://drafts.csswg.org/css-navigation-1/#at-ruledef-navigation",
      "descriptors": [],
      "value": "@navigation <navigation-condition> { <rule-list> }"
    }
  ],
  "selectors": [
    {
      "name": ":link-to()",
      "prose": "This specification defines a new :link-to() functional pseudo-class that matches link elements that link to a certain URL.",
      "href": "https://drafts.csswg.org/css-navigation-1/#link-to-pseudo"
    },
    {
      "name": ":active-navigation()",
      "prose": "This specification defines a new :active-navigation() functional pseudo-class that matches link elements that link to a certain URL that is related to a navigation that is currently active.",
      "href": "https://drafts.csswg.org/css-navigation-1/#active-navigation-pseudo"
    },
    {
      "name": ":trigger-link",
      "prose": "This specification defines a new :trigger-link that matches link elements that trigger the current navigation.",
      "href": "https://drafts.csswg.org/css-navigation-1/#trigger-link-pseudo",
      "value": ":trigger-link"
    }
  ],
  "values": [
    {
      "name": "<route-rule>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-route-rule",
      "type": "type",
      "value": "@route <dashed-ident> { <declaration-list> }"
    },
    {
      "name": "<route-descriptor>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-route-descriptor",
      "type": "type",
      "value": "<pattern-descriptor> | <init-descriptor> | <base-descriptor>"
    },
    {
      "name": "<pattern-descriptor>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-pattern-descriptor",
      "type": "type",
      "value": "pattern : <url-pattern()>"
    },
    {
      "name": "<init-descriptor>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-init-descriptor",
      "type": "type",
      "value": "<init-descriptor-name> : <string>"
    },
    {
      "name": "<init-descriptor-name>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-init-descriptor-name",
      "type": "type",
      "value": "protocol | hostname | port | pathname | search | hash"
    },
    {
      "name": "<base-descriptor>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-base-descriptor",
      "type": "type",
      "value": "base-url : stylesheet | document | <url>"
    },
    {
      "name": "url-pattern()",
      "prose": "The url-pattern() function represents a URL pattern, which can be used to match URLs.",
      "href": "https://drafts.csswg.org/css-navigation-1/#funcdef-url-pattern",
      "type": "function",
      "value": "url-pattern( <string> )"
    },
    {
      "name": "<route-location>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-route-location",
      "type": "type",
      "value": "<route-name> | <url-pattern()> | <url>"
    },
    {
      "name": "<route-name>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-route-name",
      "type": "type",
      "value": "<dashed-ident>"
    },
    {
      "name": "<active-navigation-condition>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-active-navigation-condition",
      "type": "type",
      "value": "<navigation-relation>? [ <route-location> | link-href ]?"
    },
    {
      "name": "<navigation-relation>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-relation",
      "type": "type",
      "value": "at | with | from | to"
    },
    {
      "name": "<navigation-condition>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-condition",
      "type": "type",
      "value": "not <navigation-in-parens> | <navigation-in-parens> [ and <navigation-in-parens> ]* | <navigation-in-parens> [ or <navigation-in-parens> ]*"
    },
    {
      "name": "<navigation-in-parens>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-in-parens",
      "type": "type",
      "value": "( <navigation-condition> ) | ( <navigation-test> ) | <general-enclosed>"
    },
    {
      "name": "<navigation-test>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-test",
      "type": "type",
      "value": "<navigation-location-test> | <navigation-location-between-test> | <navigation-type-test> | <navigation-phase-test>"
    },
    {
      "name": "<navigation-location-test>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-location-test",
      "type": "type",
      "value": "<navigation-location-keyword> : <route-location>"
    },
    {
      "name": "<navigation-location-keyword>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-location-keyword",
      "type": "type",
      "value": "at | with | from | to"
    },
    {
      "name": "<navigation-location-between-test>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-location-between-test",
      "type": "type",
      "value": "between : <route-location> and <route-location>"
    },
    {
      "name": "<navigation-type-test>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-type-test",
      "type": "type",
      "value": "history : <navigation-type-keyword>"
    },
    {
      "name": "<navigation-type-keyword>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-type-keyword",
      "type": "type",
      "value": "traverse | back | forward | reload"
    },
    {
      "name": "<navigation-phase-test>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-phase-test",
      "type": "type",
      "value": "phase : <navigation-phase-keyword>"
    },
    {
      "name": "<navigation-phase-keyword>",
      "href": "https://drafts.csswg.org/css-navigation-1/#typedef-navigation-phase-keyword",
      "type": "type",
      "value": "loading | ready | committed"
    }
  ],
  "warnings": [
    {
      "msg": "Dangling value",
      "name": "navigation()",
      "value": "navigation( <navigation-condition> )",
      "pureSyntax": false,
      "href": "https://drafts.csswg.org/css-navigation-1/#funcdef-when-navigation",
      "type": "function",
      "for": "@when"
    },
    {
      "msg": "Dangling value",
      "name": "navigation()",
      "value": "navigation( <navigation-condition> )",
      "pureSyntax": false,
      "href": "https://drafts.csswg.org/css-navigation-1/#funcdef-if-navigation",
      "type": "function",
      "for": "if()"
    }
  ]
}
