---
 ed/css/SVG.json | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/ed/css/SVG.json b/ed/css/SVG.json
index 0880d583ed..a4bddbe4c5 100644
--- a/ed/css/SVG.json
+++ b/ed/css/SVG.json
@@ -254,7 +254,7 @@
     {
       "name": "fill-opacity",
       "href": "https://w3c.github.io/svgwg/svg2-draft/painting.html#FillOpacityProperty",
-      "value": "<‘opacity’>",
+      "value": "<'opacity'>",
       "initial": "1",
       "appliesTo": "shapes and text content elements",
       "inherited": "yes",
@@ -285,7 +285,7 @@
     {
       "name": "stroke-opacity",
       "href": "https://w3c.github.io/svgwg/svg2-draft/painting.html#StrokeOpacityProperty",
-      "value": "<‘opacity’>",
+      "value": "<'opacity'>",
       "initial": "1",
       "appliesTo": "shapes and text content elements",
       "inherited": "yes",
