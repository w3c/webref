 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/ed/css/css-navigation.json b/ed/css/css-navigation.json
index 4f50914138..b657ce9550 100644
--- a/ed/css/css-navigation.json
+++ b/ed/css/css-navigation.json
@@ -127,7 +127,7 @@
       "name": "<active-navigation-condition>",
       "href": "https://drafts.csswg.org/css-navigation-1/#typedef-active-navigation-condition",
       "type": "type",
-      "value": "<navigation-relation>? [ <navigation-location> | link-href ] ?"
+      "value": "<navigation-relation>? [ <navigation-location> | link-href ]?"
     },
     {
       "name": "<navigation-relation>",
